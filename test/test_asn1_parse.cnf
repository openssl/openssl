openssl_conf = openssl_init

# Comment out the next line to ignore configuration errors
config_diagnostics = 1

[openssl_init]
oid_section = oids

[oids]
testoid1 = 1.2.3.4.1
testoid2 = A Very Long OID Name, 1.2.3.4.2
testoid3 = ,1.2.3.4.3
testoid4 =         OID Name     ,1.2.3.4.4
testoid5 = "         ",1.2.3.4.5
testoid6 = "      e    ",1.2.3.4.6
testoid7 =           ,1.2.3.4.7
