{-
use OpenSSL::paramnames qw(produce_param_list);
-}

#include <string.h>
#include <openssl/err.h>
#include <openssl/proverr.h>
#include "prov/digestcommon.h"
#include "internal/param_names.h"

/* Machine generated by util/perl/OpenSSL/paramnames.pm */
{- produce_param_list('static', 'digest_default_known_gettable_params',
                      'static', 'digest_get_params_find_pidx',
                      (['DIGEST_PARAM_BLOCK_SIZE',                  'size_t'],
                       ['DIGEST_PARAM_SIZE',                        'size_t'],
                       ['DIGEST_PARAM_SECURITY_CATEGORY_COLLISION', 'int'],
                       ['DIGEST_PARAM_SECURITY_CATEGORY_PREIMAGE',  'int'],
                       ['DIGEST_PARAM_XOF',                         'int'],
                       ['DIGEST_PARAM_ALGID_ABSENT',                'int'],
                      )); -}
/* End of machine generated */

const OSSL_PARAM *ossl_digest_default_gettable_params(void *provctx)
{
    return digest_default_known_gettable_params;
}

int ossl_digest_default_get_params(OSSL_PARAM params[], size_t blksz,
                                   size_t paramsz, int seccat_collision,
                                   int seccat_preimage, unsigned long flags)
{
    OSSL_PARAM *p = NULL;

    for (p = params; p->key != NULL; p++)
        switch (digest_get_params_find_pidx(p->key)) {
        default:
            break;

        case PIDX_DIGEST_PARAM_BLOCK_SIZE:
            if (!OSSL_PARAM_set_size_t(p, blksz)) {
                ERR_raise(ERR_LIB_PROV, PROV_R_FAILED_TO_SET_PARAMETER);
                return 0;
            }
            break;

        case PIDX_DIGEST_PARAM_SIZE:
            if (!OSSL_PARAM_set_size_t(p, paramsz)) {
                ERR_raise(ERR_LIB_PROV, PROV_R_FAILED_TO_SET_PARAMETER);
                return 0;
            }
            break;

        case PIDX_DIGEST_PARAM_SECURITY_CATEGORY_COLLISION:
            if (!OSSL_PARAM_set_int(p, seccat_collision)) {
                ERR_raise(ERR_LIB_PROV, PROV_R_FAILED_TO_SET_PARAMETER);
                return 0;
            }
            break;

        case PIDX_DIGEST_PARAM_SECURITY_CATEGORY_PREIMAGE:
            if (!OSSL_PARAM_set_int(p, seccat_preimage)) {
                ERR_raise(ERR_LIB_PROV, PROV_R_FAILED_TO_SET_PARAMETER);
                return 0;
            }
            break;

        case PIDX_DIGEST_PARAM_XOF:
            if (!OSSL_PARAM_set_int(p, (flags & PROV_DIGEST_FLAG_XOF) != 0)) {
                ERR_raise(ERR_LIB_PROV, PROV_R_FAILED_TO_SET_PARAMETER);
                return 0;
            }
            break;

        case PIDX_DIGEST_PARAM_ALGID_ABSENT:
            if (!OSSL_PARAM_set_int(p, (flags & PROV_DIGEST_FLAG_ALGID_ABSENT) != 0)) {
                ERR_raise(ERR_LIB_PROV, PROV_R_FAILED_TO_SET_PARAMETER);
                return 0;
            }
            break;
        }
    return 1;
}
